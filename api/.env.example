# Postgres connection (MVP data store — Neon, Vercel Postgres, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/undp_crisis_offer"

# --- Optional: only needed once SharePoint upload + Graph email are ready ---

# Easiest SharePoint upload path — an HTTP-triggered Power Automate flow,
# no Azure AD app registration needed. Takes priority over the Graph API
# path below if both are set.
POWER_AUTOMATE_UPLOAD_URL=

# Easiest email path — an HTTP-triggered Power Automate flow (e.g. using the
# Outlook "Send an email" action), no Azure AD app registration needed.
# Takes priority over the Graph API path below if both are set.
POWER_AUTOMATE_EMAIL_URL=

# Azure AD app registration (client credentials flow) — direct Graph API
# access, used for SharePoint upload if POWER_AUTOMATE_UPLOAD_URL isn't set,
# and for email if POWER_AUTOMATE_EMAIL_URL isn't set.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SharePoint (Sites.ReadWrite.All application permission + admin consent)
SHAREPOINT_SITE_ID=
SHAREPOINT_FOLDER_PATH=CrisisOffers

# Mail.Send application permission + admin consent
GRAPH_SENDER_EMAIL=

# Comma-separated list of addresses cc'd on every confirmation email
# (works with either the Power Automate or Graph API path above).
EMAIL_CC_ADDRESSES=
